# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database 
MONGODB_URI=mongodb://127.0.0.1:27017/cyberguard
POSTGRES_URI=postgresql://postgres:password@127.0.0.1:5432/postgres
REDIS_URL=redis://127.0.0.1:6379
# InfluxDB Configuration
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=cyberguard-super-secret-token
INFLUXDB_ORG=cyberguard
INFLUXDB_BUCKET=network_traffic

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ML Service
ML_SERVICE_URL=http://localhost:8000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email Configuration (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@cyberguard.ai

# Azure Configuration (Production)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_APP_INSIGHTS_KEY=

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=your-session-secret-key

# API Keys (for external services)
THREAT_INTEL_API_KEY=
GEOLOCATION_API_KEY=

# Feature Flags
ENABLE_THREAT_INTEL=true
ENABLE_EMAIL_ALERTS=false
ENABLE_SMS_ALERTS=false
